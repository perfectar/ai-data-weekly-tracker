# Copy this file to config/email.env and fill in the values.
# Gmail requires an App Password, not your normal Google account password.

GMAIL_SMTP_USER=your_gmail_address@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
NOTICE_TO=your_gmail_address@gmail.com

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
REPORT_URL=https://perfectar.github.io/ai-data-weekly-tracker/
